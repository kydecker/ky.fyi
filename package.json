{
  "name": "ky.fyi",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.17.1"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "astro dev",
    "build": "astro check && astro build --remote",
    "preview": "astro preview",
    "check": "astro check && biome check",
    "check:fix": "astro check && biome check --write",
    "test": "playwright test",
    "html-validate": "pnpm build && pnpm exec html-validate dist/*.html",
    "check-links": "lychee --config .lychee.toml .",
    "knip": "knip"
  },
  "simple-git-hooks": {
    "pre-commit": "./node_modules/.bin/nano-staged"
  },
  "nano-staged": {
    "*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,json,jsonc,css,astro}": [
      "biome check --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/db": "0.21.2",
    "@astrojs/markdown-remark": "^7.1.2",
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/netlify": "^6.6.5",
    "@astrojs/react": "^5.0.5",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@nanostores/react": "^1.1.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "astro": "^5.18.2",
    "astro-expressive-code": "^0.42.0",
    "autoprefixer": "^10.5.0",
    "classnames": "^2.5.1",
    "cssnano": "^8.0.1",
    "dayjs": "^1.11.20",
    "fathom-client": "^3.7.2",
    "howler": "^2.2.4",
    "markdown-it": "^14.2.0",
    "motion": "^12.40.0",
    "nanoid": "^5.1.11",
    "nanostores": "^1.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rehype-autolink-headings": "^7.1.0",
    "remark-imgattr": "^1.1.1",
    "sanitize-html": "^2.17.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.60.0",
    "@radix-ui/colors": "^3.0.0",
    "@types/howler": "^2.2.13",
    "@types/node": "^25.9.1",
    "hastscript": "^9.0.1",
    "html-validate": "^11.3.0",
    "knip": "^6.14.2",
    "nano-staged": "^1.0.2",
    "postcss-html": "^1.8.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3"
  }
}
