{
  "name": "ky.fyi",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "astro dev",
    "build": "wrangler types && astro check && astro build",
    "build:only": "astro build",
    "preview": "astro preview",
    "check": "astro check && biome check",
    "check:fix": "astro check && biome check --write",
    "test": "playwright test",
    "html-validate": "pnpm build && pnpm exec html-validate dist/client/**/*.html",
    "check-links": "lychee --config .lychee.toml .",
    "knip": "knip"
  },
  "simple-git-hooks": {
    "pre-commit": "./node_modules/.bin/nano-staged"
  },
  "nano-staged": {
    "*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,json,jsonc,css,astro}": [
      "biome check --write"
    ]
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "14.0.0-beta.2",
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "7.0.0-beta.2",
    "@astrojs/react": "6.0.0-beta.1",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@libsql/client": "^0.17.4",
    "@nanostores/react": "^1.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "7.0.0-beta.4",
    "astro-expressive-code": "^0.43.1",
    "autoprefixer": "^10.5.0",
    "classnames": "^2.5.1",
    "cssnano": "^8.0.2",
    "dayjs": "^1.11.21",
    "drizzle-orm": "^0.45.2",
    "fathom-client": "^3.7.2",
    "howler": "^2.2.4",
    "markdown-it": "^14.2.0",
    "motion": "^12.40.0",
    "nanoid": "^5.1.15",
    "nanostores": "^1.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-autolink-headings": "^7.1.0",
    "remark-imgattr": "^1.1.1",
    "sanitize-html": "^2.17.5",
    "sharp": "^0.35.2",
    "wrangler": "^4.103.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.5.0",
    "@playwright/test": "^1.61.0",
    "@radix-ui/colors": "^3.0.0",
    "@types/howler": "^2.2.13",
    "@types/node": "^25.9.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "hastscript": "^9.0.1",
    "html-validate": "^11.5.3",
    "knip": "^6.17.1",
    "nano-staged": "^1.0.2",
    "postcss-html": "^1.8.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.7.0",
  "bugs": {
    "url": "https://github.com/kydecker/ky.fyi/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kydecker/ky.fyi"
  }
}
