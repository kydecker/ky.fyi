{
  "name": "ky.fyi",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.17.1"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "astro dev",
    "build": "astro check && astro build --remote",
    "preview": "astro preview",
    "check": "astro check && biome check",
    "check:fix": "astro check && biome check --write",
    "test": "playwright test",
    "html-validate": "pnpm build && pnpm exec html-validate dist/*.html",
    "check-links": "lychee --config .lychee.toml .",
    "knip": "knip"
  },
  "simple-git-hooks": {
    "pre-commit": "./node_modules/.bin/nano-staged"
  },
  "nano-staged": {
    "*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,json,jsonc,css,astro}": [
      "biome check --write"
    ]
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/db": "0.20.1",
    "@astrojs/markdown-remark": "^7.1.0",
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/netlify": "^6.6.5",
    "@astrojs/react": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@nanostores/react": "^1.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.6",
    "astro-expressive-code": "^0.41.7",
    "autoprefixer": "^10.5.0",
    "classnames": "^2.5.1",
    "cssnano": "^7.1.5",
    "dayjs": "^1.11.20",
    "fathom-client": "^3.7.2",
    "howler": "^2.2.4",
    "markdown-it": "^14.1.1",
    "motion": "^12.38.0",
    "nanoid": "^5.1.9",
    "nanostores": "^1.3.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rehype-autolink-headings": "^7.1.0",
    "remark-imgattr": "^1.1.1",
    "sanitize-html": "^2.17.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.59.1",
    "@radix-ui/colors": "^3.0.0",
    "@types/howler": "^2.2.12",
    "@types/node": "^25.6.0",
    "hastscript": "^9.0.1",
    "html-validate": "^10.13.1",
    "knip": "^6.5.0",
    "nano-staged": "^1.0.2",
    "postcss-html": "^1.8.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3"
  }
}
