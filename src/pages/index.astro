---
import { getCollection } from "astro:content";
import Center from "../components/Center.astro";
import GuestbookFeed from "../components/Home/GuestbookFeed.astro";
import ProjectGrid from "../components/Home/ProjectGrid.astro";
import Synth from "../components/Synth/Synth.astro";
import { siteInfo } from "../constants/site-info";
import BaseLayout from "../layouts/BaseLayout.astro";

const work = await getCollection("work");
const posts = await getCollection("posts");

const feed = work
  .map((project) => ({
    id: project.id,
    ...project.data,
  }))
  .sort((a, b) => b.year - a.year);

const writing = posts
  .sort(
    (a, b) => b.data.datePublished.getTime() - a.data.datePublished.getTime(),
  )
  .map((post) => ({
    id: post.id,
    title: post.data.title,
    description: post.data.description,
    date: post.data.datePublished,
    url: `/posts/${post.id}`,
  }));
---

<BaseLayout
  title={siteInfo.name}
  description={siteInfo.description}
  includeFooter
>
  <section class="home">
    <Center>
      <h1 class="visuallyhidden">Ky designs and builds for the web</h1>
      <div class="intro">
        <p>
          <strong><a href="/about">Ky Decker</a>&nbsp;</strong>{" "}
          designs <abbr title="world-wide websites">www</abbr> and writes <abbr
            title="cascading style sheets">CSS</abbr
          > in <abbr title="New York City">NYC</abbr> with{" "}
          <button type="button" data-sam-button>Samwise</button>
        </p>
      </div>
      <div class="synth">
        <Synth />
      </div>
    </Center>
  </section>
  <section>
    <Center>
      <h2>Projects</h2>
      <ProjectGrid items={feed} />
    </Center>
  </section>
  <section>
    <Center>
      <h2>Writing</h2>
      <ul class="writing-list">
        {
          writing.map((post) => (
            <li class="writing-entry">
              <time class="writing-date" datetime={post.date.toISOString()}>
                {post.date.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                })}
              </time>
              <div class="writing-body">
                <h3 class="writing-title">
                  <a href={post.url}>{post.title}</a>
                </h3>
                <p class="writing-description">{post.description}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </Center>
  </section>
  <section>
    <Center>
      <h2>From the <a href="/guestbook">guestbook</a></h2>
    </Center>
    <GuestbookFeed />
  </section>

  <script>
    import * as Fathom from "fathom-client";
    import { addSam } from "../stores/sam";

    function setupSam() {
      const samButton = document.querySelector("[data-sam-button]");
      samButton?.addEventListener("click", () => addSam());
    }

    function setupAbbr() {
      document.querySelectorAll(".intro abbr[title]").forEach((abbr) => {
        abbr.addEventListener("click", () => abbr.replaceWith(abbr.title));
      });
    }

    setupSam();
    setupAbbr();

    document.addEventListener("astro:after-swap", () => {
      setupSam();
      setupAbbr();
    });

    document.addEventListener("astro:page-load", () => {
      document
        .querySelector("[data-sam-button]")
        ?.addEventListener("click", () => {
          Fathom.trackEvent("stickers: add sam");
        });

      document
        .querySelector("[data-sam-shoo]")
        ?.addEventListener("click", () => {
          Fathom.trackEvent("stickers: shoo sam");
        });
    });
  </script>

  <style>
    .visuallyhidden {
      clip: rect(0 0 0 0);
      clip-path: inset(50%);
      height: 1px;
      overflow: hidden;
      position: absolute;
      white-space: nowrap;
      width: 1px;
    }

    .home {
      display: flex;
      flex-direction: column;
      gap: var(--space-3xl);
    }

    @keyframes rotate {
      0% {
        transform: rotate(0deg);
      }

      100% {
        transform: rotate(360deg);
      }
    }

    .intro {
      padding-block: var(--space-2xl);
      text-wrap: pretty;
      user-select: none;

      p {
        font-size: var(--step-4);
        letter-spacing: var(--letter-spacing-condensed);
        line-height: var(--line-height-tight);
        padding-block-end: var(--space-l);
      }

      abbr {
        cursor: help;
        text-decoration-color: var(--gray-8);
        text-decoration-style: wavy;
        text-underline-offset: max(0.1em, 2.5px);

        @media (hover: hover) and (pointer: fine) {
          &:hover {
            text-decoration-color: var(--gray-11);
          }
        }
      }

      a,
      button {
        background: unset;
        border: unset;
        margin: unset;
        line-height: unset;
        display: unset;
        padding: unset;
        cursor: pointer;
        color: inherit;
        text-decoration: underline;
        text-decoration-color: var(--gray-8);
        text-underline-offset: max(0.1em, 2.5px);
        transition:
          text-decoration-color 0.2s ease-in-out,
          font-weight 0.2s ease-in-out;

        @media (hover: hover) and (pointer: fine) {
          &:hover {
            font-weight: var(--font-weight-bold);
            text-decoration-color: var(--gray-11);
          }
        }
      }
    }

    .synth {
      display: flex;
      align-items: center;
      justify-content: center;

      @media (width > 640px) {
        background: var(--gray-3);
        border-radius: var(--radius-m);
        padding: var(--space-xl) var(--space-l);
      }
    }

    [data-sam-button] {
      cursor: pointer;

      &:active {
        transform: scale(0.95);
      }
    }

    section {
      width: 100%;
      padding-block-end: var(--space-3xl);
    }

    h2 {
      font-size: var(--step-1);
      margin-block-end: var(--space-m);
    }

    .writing-list {
      list-style: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-m);
    }

    .writing-entry {
      display: grid;
      grid-template-columns: 7ch 1fr;
      gap: var(--space-m);
      align-items: baseline;
    }

    .writing-date {
      color: var(--gray-11);
      font-size: var(--step--1);
      font-variant-numeric: tabular-nums;
    }

    .writing-body {
      display: flex;
      flex-direction: column;
      gap: var(--space-2xs);
    }

    .writing-title {
      font-size: var(--step-0);
      font-weight: var(--font-weight-normal);
      text-wrap: pretty;
    }

    .writing-description {
      color: var(--gray-11);
      font-size: var(--step--1);
      text-wrap: pretty;
    }
  </style>
</BaseLayout>
