---
import { Image } from "astro:assets";

interface Props {
  items: Array<{
    id: string;
    title: string;
    description?: string;
    url: string;
    category: string;
    year: number;
    previewImage?: {
      image: ImageMetadata;
      alt: string;
    };
  }>;
}

const { items } = Astro.props;
---

<ul class="project-grid">
  {
    items.map((item) => (
      <li>
        <a href={item.url} class="project-card">
          <div class="project-thumbnail">
            {item.previewImage ? (
              <Image
                src={item.previewImage.image}
                alt={item.previewImage.alt}
                width={392}
                height={205}
              />
            ) : (
              <div class="project-thumbnail-placeholder" />
            )}
          </div>
          <div class="project-info">
            <h3 class="project-title">{item.title}</h3>
            <div class="project-meta">
              <span class="project-category">{item.category}</span>
              <time class="project-year">{item.year}</time>
            </div>
          </div>
        </a>
      </li>
    ))
  }
</ul>

<style>
  .project-grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-m);
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    text-decoration: none;
    color: inherit;
    border-radius: var(--radius-xs);

    &:focus-visible {
      outline: var(--gray-12) solid 2px;
      outline-offset: 3px;
    }
  }

  .project-thumbnail {
    background-color: var(--gray-3);
    border-radius: var(--radius-xs);
    aspect-ratio: 1.91 / 1;
    overflow: hidden;

    img,
    .project-thumbnail-placeholder {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
  }

  .project-info {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-s);
  }

  .project-title {
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
    flex: 1;
    min-width: 0;
  }

  .project-meta {
    display: flex;
    gap: var(--space-xs);
    flex-shrink: 0;
  }

  .project-category,
  .project-year {
    color: var(--gray-11);
    font-size: var(--step--1);
    font-variant-numeric: tabular-nums;
  }

  .project-category {
    display: none;

    @media (width > 640px) {
      display: inline;
    }
  }
</style>
